# Copy to .env for local development; never commit .env.
# All values below are safe examples — no real secrets, no real credentials.

# ─── Backend ──────────────────────────────────────────────────────────────────

APP_NAME=wheel-vocabulary-api
APP_VERSION=0.1.0
ENVIRONMENT=development

# SQLite database path for local development.
# Use sqlite:///:memory: for integration tests.
DATABASE_URL=sqlite:///./data/wheel_vocabulary.db

# CORS allowed origins (comma-separated list).
CORS_ORIGINS=http://localhost:5173

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ─── Frontend ─────────────────────────────────────────────────────────────────

VITE_API_BASE_URL=http://localhost:8000
